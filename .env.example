# ── Runtime ──────────────────────────────────────────────────────────
ENVIRONMENT=dev
SERVICE_NAME=jwebmp-client
PORT=8080
BASE_URL=http://localhost:8080

# ── Logging ─────────────────────────────────────────────────────────
LOGGING_BACKEND=log4j2
ENABLE_DEBUG_LOGS=false

# ── Observability (optional) ────────────────────────────────────────
TRACING_ENABLED=false
METRICS_EXPORT=disabled

# ── Testing ─────────────────────────────────────────────────────────
SKIP_INTEGRATION_TESTS=true
